import React, { useState, useEffect, useRef } from "react";
import { Check, HelpCircle, ArrowRight, ShieldCheck, Zap, Info } from "lucide-react";
import { PRICING_TIERS, CURRENCIES, calculatePrice } from "../pricingConfig";

export default function PricingPage() {
  // Direct DOM references for price values to prevent component-wide re-renders
  const pageBillingToggleRef = useRef<HTMLInputElement>(null);
  const pageCurrencySelectRef = useRef<HTMLSelectElement>(null);

  const starterPriceRef = useRef<HTMLSpanElement>(null);
  const starterSymbolRef = useRef<HTMLSpanElement>(null);
  const starterSubtextRef = useRef<HTMLSpanElement>(null);

  const proPriceRef = useRef<HTMLSpanElement>(null);
  const proSymbolRef = useRef<HTMLSpanElement>(null);
  const proSubtextRef = useRef<HTMLSpanElement>(null);

  const entPriceRef = useRef<HTMLSpanElement>(null);
  const entSymbolRef = useRef<HTMLSpanElement>(null);
  const entSubtextRef = useRef<HTMLSpanElement>(null);

  const [activeFaq, setActiveFaq] = useState<number | null>(null);
  const [contactSubmitted, setContactSubmitted] = useState(false);

  // Directly update price nodes in the DOM
  const performIsolatedPricingUpdate = () => {
    const isAnnual = pageBillingToggleRef.current ? pageBillingToggleRef.current.checked : false;
    const selectedCurrency = (pageCurrencySelectRef.current?.value || "USD") as keyof typeof CURRENCIES;
    const cycle = isAnnual ? "annual" : "monthly";

    const currencyConfig = CURRENCIES[selectedCurrency];

    const nodes = {
      starter: {
        price: starterPriceRef,
        symbol: starterSymbolRef,
        subtext: starterSubtextRef,
        base: PRICING_TIERS.find(t => t.id === "starter")?.baseMonthlyUSD || 29
      },
      pro: {
        price: proPriceRef,
        symbol: proSymbolRef,
        subtext: proSubtextRef,
        base: PRICING_TIERS.find(t => t.id === "pro")?.baseMonthlyUSD || 79
      },
      enterprise: {
        price: entPriceRef,
        symbol: entSymbolRef,
        subtext: entSubtextRef,
        base: PRICING_TIERS.find(t => t.id === "enterprise")?.baseMonthlyUSD || 199
      }
    };

    Object.entries(nodes).forEach(([_, refs]) => {
      const calc = calculatePrice(refs.base, selectedCurrency, cycle);
      
      if (refs.symbol.current && refs.symbol.current.textContent !== currencyConfig.symbol) {
        refs.symbol.current.textContent = currencyConfig.symbol;
      }
      
      const newPriceStr = calc.monthlyRate.toLocaleString();
      if (refs.price.current && refs.price.current.textContent !== newPriceStr) {
        refs.price.current.textContent = newPriceStr;
      }
      
      const newSubtext = cycle === "annual" 
        ? `Billed annually (Total ${calc.formattedTotal}/yr)` 
        : "Billed month-to-month";
      if (refs.subtext.current && refs.subtext.current.textContent !== newSubtext) {
        refs.subtext.current.textContent = newSubtext;
      }
    });
  };

  useEffect(() => {
    // Initial paint
    performIsolatedPricingUpdate();

    // Bind event listeners to DOM inputs
    const toggleEl = pageBillingToggleRef.current;
    const selectEl = pageCurrencySelectRef.current;

    if (toggleEl) {
      toggleEl.addEventListener("change", performIsolatedPricingUpdate);
    }
    if (selectEl) {
      selectEl.addEventListener("change", performIsolatedPricingUpdate);
    }

    return () => {
      if (toggleEl) {
        toggleEl.removeEventListener("change", performIsolatedPricingUpdate);
      }
      if (selectEl) {
        selectEl.removeEventListener("change", performIsolatedPricingUpdate);
      }
    };
  }, []);

  const handleContactSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    setContactSubmitted(true);
  };

  return (
    <div className="bg-oceanic-noir text-arctic-powder min-h-screen py-24 px-6 relative overflow-hidden">
      <div className="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,#114C5A_0%,transparent_50%)] opacity-30 pointer-events-none" />

      <div className="max-w-6xl mx-auto relative z-10">
        {/* Page Header */}
        <div className="text-center mb-16 border-b border-mystic-mint/10 pb-12">
          <span className="inline-block px-3 py-1 text-xs font-mono tracking-widest text-forsythia bg-forsythia/10 border border-forsythia/20 rounded-full mb-3 uppercase font-bold">
            GRID PRICING MATRIX
          </span>
          <h1 className="text-4xl md:text-5xl font-sans font-extrabold text-white tracking-tight mb-4">
            Dynamic Bandwidth Calculations
          </h1>
          <p className="text-mystic-mint/60 max-w-2xl mx-auto text-sm font-sans">
            Scale your agent operations with localized regional pricing and annual discounts updated instantly via our high-performance DOM layer.
          </p>

          {/* Pricing Config Controls (Direct DOM Actions) */}
          <div className="inline-flex flex-wrap items-center justify-center gap-4 bg-nocturnal-expedition/40 border border-mystic-mint/10 p-3 rounded-2xl mt-10">
            {/* Currency Select */}
            <div className="flex items-center gap-2 px-3">
              <label htmlFor="page-currency-select" className="text-xs font-mono text-mystic-mint/60 uppercase tracking-wider font-bold">CURRENCY:</label>
              <select
                id="page-currency-select"
                ref={pageCurrencySelectRef}
                className="bg-oceanic-noir text-white text-xs font-mono rounded border border-mystic-mint/20 px-3 py-1.5 focus:outline-none focus:border-forsythia cursor-pointer"
              >
                <option value="USD">USD ($)</option>
                <option value="EUR">EUR (€)</option>
                <option value="INR">INR (₹)</option>
              </select>
            </div>

            <div className="h-6 w-[1px] bg-mystic-mint/10 hidden sm:block" />

            {/* Cycle Toggle */}
            <div className="flex items-center gap-3 px-3">
              <span className="text-xs font-mono text-mystic-mint/60">Monthly</span>
              <label htmlFor="page-billing-toggle" className="relative inline-flex items-center cursor-pointer">
                <input
                  type="checkbox"
                  id="page-billing-toggle"
                  ref={pageBillingToggleRef}
                  className="sr-only peer"
                />
                <div className="w-11 h-6 bg-nocturnal-expedition border border-mystic-mint/10 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-forsythia after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-forsythia/20" />
              </label>
              <span className="text-xs font-mono text-white flex items-center gap-1 font-bold">
                Annual <span className="text-[10px] bg-forsythia text-oceanic-noir px-1.5 py-0.5 rounded uppercase font-extrabold">-20%</span>
              </span>
            </div>
          </div>
        </div>

        {/* PRICE CARDS */}
        <div className="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
          {/* Starter Plan */}
          <div className="bg-nocturnal-expedition/20 border border-mystic-mint/10 p-8 rounded-3xl relative flex flex-col justify-between hover-card-interactive gpu-accelerated">
            <div>
              <span className="font-mono text-xs text-mystic-mint/50 uppercase block mb-1">STARTER PACKET</span>
              <h3 className="text-2xl font-sans font-bold text-white mb-4">Starter Apex</h3>
              <p className="text-xs text-mystic-mint/60 mb-6 font-sans">For developers prototyping local model workflows and autonomous agent loops.</p>
              
              <div className="flex items-baseline gap-1 mb-2">
                <span ref={starterSymbolRef} className="text-xl font-mono text-forsythia font-bold">$</span>
                <span ref={starterPriceRef} className="text-4xl font-mono text-white font-extrabold tracking-tight">29</span>
                <span className="text-xs text-mystic-mint/50 font-mono">/ mo</span>
              </div>
              <span ref={starterSubtextRef} className="text-[10px] font-mono text-forsythia/70 block mb-8">Billed month-to-month</span>

              <div className="border-t border-mystic-mint/5 pt-6 flex flex-col gap-3 mb-8">
                {PRICING_TIERS[0].features.map((feat, idx) => (
                  <div key={idx} className="flex gap-2 text-xs text-mystic-mint/80">
                    <Check className="w-4 h-4 text-forsythia shrink-0" />
                    <span>{feat}</span>
                  </div>
                ))}
              </div>
            </div>
            <button className="w-full py-3 bg-nocturnal-expedition text-white font-mono text-xs font-bold uppercase rounded-xl hover:bg-nocturnal-expedition/80 cursor-pointer">
              Launch Agent Matrix
            </button>
          </div>

          {/* Pro Plan (Popular) */}
          <div className="bg-nocturnal-expedition border-2 border-forsythia p-8 rounded-3xl relative flex flex-col justify-between hover-card-interactive gpu-accelerated shadow-xl shadow-forsythia/5">
            <div className="absolute -top-3.5 right-6 bg-forsythia text-oceanic-noir font-mono text-[9px] font-extrabold px-3 py-1 rounded-full uppercase tracking-widest">
              POPULAR_CORE
            </div>
            <div>
              <span className="font-mono text-xs text-forsythia uppercase block mb-1">PROFESSIONAL CORES</span>
              <h3 className="text-2xl font-sans font-bold text-white mb-4">Professional Core</h3>
              <p className="text-xs text-mystic-mint/80 mb-6 font-sans">Ideal for scaling teams running multiple concurrent micro-agent swarms.</p>
              
              <div className="flex items-baseline gap-1 mb-2">
                <span ref={proSymbolRef} className="text-xl font-mono text-forsythia font-bold">$</span>
                <span ref={proPriceRef} className="text-4xl font-mono text-white font-extrabold tracking-tight">79</span>
                <span className="text-xs text-mystic-mint/50 font-mono">/ mo</span>
              </div>
              <span ref={proSubtextRef} className="text-[10px] font-mono text-forsythia/70 block mb-8">Billed month-to-month</span>

              <div className="border-t border-mystic-mint/10 pt-6 flex flex-col gap-3 mb-8">
                {PRICING_TIERS[1].features.map((feat, idx) => (
                  <div key={idx} className="flex gap-2 text-xs text-white">
                    <Check className="w-4 h-4 text-forsythia shrink-0" />
                    <span>{feat}</span>
                  </div>
                ))}
              </div>
            </div>
            <button className="w-full py-3 bg-forsythia text-oceanic-noir font-mono text-xs font-bold uppercase rounded-xl hover:bg-white cursor-pointer">
              Deploy Swarm Core
            </button>
          </div>

          {/* Enterprise Grid */}
          <div className="bg-nocturnal-expedition/20 border border-mystic-mint/10 p-8 rounded-3xl relative flex flex-col justify-between hover-card-interactive gpu-accelerated">
            <div>
              <span className="font-mono text-xs text-mystic-mint/50 uppercase block mb-1">ENTERPRISE GRID</span>
              <h3 className="text-2xl font-sans font-bold text-white mb-4">Enterprise Grid</h3>
              <p className="text-xs text-mystic-mint/60 mb-6 font-sans">Isolated high-throughput architecture and dynamic multi-region routing SLAs.</p>
              
              <div className="flex items-baseline gap-1 mb-2">
                <span ref={entSymbolRef} className="text-xl font-mono text-forsythia font-bold">$</span>
                <span ref={entPriceRef} className="text-4xl font-mono text-white font-extrabold tracking-tight">199</span>
                <span className="text-xs text-mystic-mint/50 font-mono">/ mo</span>
              </div>
              <span ref={entSubtextRef} className="text-[10px] font-mono text-forsythia/70 block mb-8">Billed month-to-month</span>

              <div className="border-t border-mystic-mint/5 pt-6 flex flex-col gap-3 mb-8">
                {PRICING_TIERS[2].features.map((feat, idx) => (
                  <div key={idx} className="flex gap-2 text-xs text-mystic-mint/80">
                    <Check className="w-4 h-4 text-forsythia shrink-0" />
                    <span>{feat}</span>
                  </div>
                ))}
              </div>
            </div>
            <button className="w-full py-3 bg-nocturnal-expedition text-white font-mono text-xs font-bold uppercase rounded-xl hover:bg-nocturnal-expedition/80 cursor-pointer">
              Contact Solutions Node
            </button>
          </div>
        </div>

        {/* COMPARISON TABLE */}
        <div className="bg-nocturnal-expedition/20 border border-mystic-mint/10 rounded-3xl p-8 mb-24 overflow-x-auto">
          <h3 className="text-xl font-sans font-bold text-white mb-6">Compute Matrix Direct Comparisons</h3>
          <table className="w-full text-left font-mono text-xs text-mystic-mint/80 min-w-[600px]">
            <thead>
              <tr className="border-b border-mystic-mint/10 pb-4">
                <th className="py-3 text-mystic-mint/40 font-bold uppercase tracking-wider">CAPABILITY</th>
                <th className="py-3 text-white">STARTER APEX</th>
                <th className="py-3 text-white">PRO CORE</th>
                <th className="py-3 text-white">ENTERPRISE GRID</th>
              </tr>
            </thead>
            <tbody>
              <tr className="border-b border-mystic-mint/5">
                <td className="py-4 text-white font-bold">Automated runs / mo</td>
                <td className="py-4">10,000</td>
                <td className="py-4 font-bold text-forsythia">150,000</td>
                <td className="py-4">Unlimited</td>
              </tr>
              <tr className="border-b border-mystic-mint/5">
                <td className="py-4 text-white font-bold">Proxy Latency Routing</td>
                <td className="py-4 text-mystic-mint/60">Standard Route</td>
                <td className="py-4 text-forsythia font-bold">Lowest Latency Priority</td>
                <td className="py-4">Isolated private lanes</td>
              </tr>
              <tr className="border-b border-mystic-mint/5">
                <td className="py-4 text-white font-bold">Security Shield Level</td>
                <td className="py-4">Standard Sandbox</td>
                <td className="py-4">Dynamic Prompt Scan</td>
                <td className="py-4 text-emerald-400 font-bold">Military Isolation Guard</td>
              </tr>
              <tr className="border-b border-mystic-mint/5">
                <td className="py-4 text-white font-bold">gRPC Bandwidth Tunnel</td>
                <td className="py-4">Shared</td>
                <td className="py-4">Priority Core</td>
                <td className="py-4">Isolated Dedicated Tunnel</td>
              </tr>
              <tr>
                <td className="py-4 text-white font-bold">SLA Guarantee</td>
                <td className="py-4">None</td>
                <td className="py-4">99.9%</td>
                <td className="py-4 text-forsythia font-bold">99.99% custom SLA</td>
              </tr>
            </tbody>
          </table>
        </div>

        {/* FAQ ACCORDION */}
        <div className="max-w-3xl mx-auto mb-24">
          <h3 className="text-2xl font-sans font-bold text-white text-center mb-8">Compute Matrix FAQ</h3>
          <div className="flex flex-col gap-4">
            {[
              { q: "How is the dynamic pricing matrix computed?", a: "Prices are derived in real-time by checking the currency multiplier matrix from pricingConfig. Your regional rates (INR, EUR) and a 20% annual saving discount are calculated instantaneously directly in your viewport DOM for lag-free performance." },
              { q: "What is an autonomous multi-agent swarm?", a: "Swarms are collaborative pipelines of dedicated AI micro-agents that work together asynchronously. Instead of single sequential calls, swarms delegate sub-tasks dynamically over gRPC, auditing work in real-time." },
              { q: "Can I deploy NeuralOS on isolated on-premise hardware?", a: "Yes. The Enterprise Grid plan supports complete physical air-gapped isolation with isolated compliance logs and cryptographic signatures." }
            ].map((faq, idx) => (
              <div 
                key={idx}
                className="bg-nocturnal-expedition/30 border border-mystic-mint/10 rounded-2xl overflow-hidden transition-all"
              >
                <button
                  onClick={() => setActiveFaq(activeFaq === idx ? null : idx)}
                  className="w-full p-5 text-left flex justify-between items-center cursor-pointer focus:outline-none font-sans font-bold text-sm text-white"
                >
                  <span>{faq.q}</span>
                  <span className="text-forsythia font-mono text-xs">{activeFaq === idx ? "[-]" : "[+]"}</span>
                </button>
                {activeFaq === idx && (
                  <div className="px-5 pb-5 text-xs text-mystic-mint/70 font-sans leading-relaxed border-t border-mystic-mint/5 pt-4">
                    {faq.a}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>

        {/* ENTERPRISE CONTACT */}
        <div className="max-w-xl mx-auto bg-nocturnal-expedition/30 border border-mystic-mint/10 p-8 rounded-3xl">
          <h3 className="text-xl font-sans font-bold text-white text-center mb-2">Request Custom Slab Allocation</h3>
          <p className="text-xs text-mystic-mint/60 text-center mb-6 font-sans">For custom pricing queries, private clusters, and military-grade isolation limits.</p>
          
          {contactSubmitted ? (
            <div className="p-4 bg-forsythia/10 border border-forsythia/20 rounded-xl text-center text-xs font-mono text-forsythia">
              ✓ Message dispatched to nearest Enterprise Node. A dedicated solution architect will contact you within 2ms.
            </div>
          ) : (
            <form onSubmit={handleContactSubmit} className="flex flex-col gap-4">
              <div>
                <label className="block text-[10px] font-mono text-mystic-mint/50 uppercase tracking-widest mb-1.5 font-bold">Node Operator Name</label>
                <input required type="text" className="w-full bg-oceanic-noir border border-mystic-mint/10 rounded-lg p-2.5 text-xs font-mono text-white focus:outline-none focus:border-forsythia" placeholder="Agent S. Sterling" />
              </div>
              <div>
                <label className="block text-[10px] font-mono text-mystic-mint/50 uppercase tracking-widest mb-1.5 font-bold">Secure Routing Email</label>
                <input required type="email" className="w-full bg-oceanic-noir border border-mystic-mint/10 rounded-lg p-2.5 text-xs font-mono text-white focus:outline-none focus:border-forsythia" placeholder="operator@vercel-grid.io" />
              </div>
              <div>
                <label className="block text-[10px] font-mono text-mystic-mint/50 uppercase tracking-widest mb-1.5 font-bold">Compute Bandwidth Needs</label>
                <textarea required rows={3} className="w-full bg-oceanic-noir border border-mystic-mint/10 rounded-lg p-2.5 text-xs font-mono text-white focus:outline-none focus:border-forsythia" placeholder="Describe the scale of autonomous swarms you plan to route..." />
              </div>
              <button type="submit" className="w-full py-3 bg-forsythia text-oceanic-noir font-mono text-xs font-bold uppercase rounded-lg hover:bg-white transition-all cursor-pointer">
                Submit Security Proposal
              </button>
            </form>
          )}
        </div>
      </div>
    </div>
  );
}
