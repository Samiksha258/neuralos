import React, { useState, useEffect } from "react";
import { 
  Play, 
  Settings, 
  Cpu, 
  Layers, 
  ShieldCheck, 
  Terminal, 
  Bell, 
  Command, 
  CheckCircle2, 
  ChevronLeft, 
  ChevronRight, 
  Activity, 
  HelpCircle,
  TrendingUp,
  RefreshCw,
  FolderSync,
  Radio,
  FileCheck,
  Zap,
  Power
} from "lucide-react";
import { LogEntry, AIEmployee, WorkflowNode } from "../types";

export default function DashboardPage() {
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);
  const [logs, setLogs] = useState<LogEntry[]>([
    { timestamp: "03:41:02", level: "SYSTEM", message: "Kernel core initialized. Node US-East-4 operational.", node: "NODE_CORE_0" },
    { timestamp: "03:41:05", level: "INFO", message: "Swarms synchronization handshake established over gRPC.", node: "COORDINATOR" },
    { timestamp: "03:41:12", level: "SUCCESS", message: "Prompt injection scans passed. Content shield nominal.", node: "GUARD_SHIELD" },
    { timestamp: "03:42:01", level: "INFO", message: "Routing payload to Gemini-2.5-Pro: latency 8.2ms", node: "LLM_ROUTER" },
  ]);

  const [employees, setEmployees] = useState<AIEmployee[]>([
    { id: "e1", name: "Sterling.ai", role: "Swarm Lead & Lead Architect", avatar: "S", status: "executing", activeTask: "Routing multi-agent code compilation", efficiency: 98.4, tokensProcessed: 142090 },
    { id: "e2", name: "Apex.ai", role: "Security Auditor & Shield Proxy", avatar: "A", status: "thinking", activeTask: "Scanning gRPC payloads for key leaks", efficiency: 99.8, tokensProcessed: 89310 },
    { id: "e3", name: "Mint.ai", role: "Cache & Query Optimizer", avatar: "M", status: "idle", activeTask: "Pruning ledger cache entries", efficiency: 95.1, tokensProcessed: 41200 },
  ]);

  const [workflowNodes, setWorkflowNodes] = useState<WorkflowNode[]>([
    { id: "n1", label: "TCP_INGESTION_TUNNEL", type: "trigger", status: "success", description: "Captures raw TLS streams" },
    { id: "n2", label: "GUARDRAIL_SHIELD_V3", type: "condition", status: "active", description: "Performs real-time content vetting" },
    { id: "n3", label: "DYNAMIC_ROUTING_STAGE", type: "action", status: "idle", description: "Resolves minimum latency" },
    { id: "n4", label: "BLOCK_CRYPT_LEDGER", type: "action", status: "idle", description: "Writes securely to shared disk" },
  ]);

  const [activeTab, setActiveTab] = useState<"orchestrator" | "analytics" | "agents">("orchestrator");
  const [chartAnimatePercent, setChartAnimatePercent] = useState(0);
  const [commandPaletteOpen, setCommandPaletteOpen] = useState(false);
  const [notificationCount, setNotificationCount] = useState(3);
  const [simulating, setSimulating] = useState(false);

  // Auto-feed simulation logs every 3 seconds
  useEffect(() => {
    const messages = [
      "Dynamic cost-balance adjusted. Savings increased by 12%.",
      "Shield intercepts suspicious query containing unescaped system properties.",
      "Pruning legacy Cache blocks: freed 14.8 GB memory space.",
      "Vercel Edge node synchronized. Ping delay lowered from 4.2ms to 1.8ms.",
      "Autonomous swarm executed a code modification patch successfully."
    ];
    const components = ["LLM_ROUTER", "GUARD_SHIELD", "MINT_OPTIMIZER", "EDGE_CDN", "SWARM_LEAD"];
    const levels: ("INFO" | "SUCCESS" | "WARNING")[] = ["INFO", "SUCCESS", "WARNING"];

    const interval = setInterval(() => {
      const now = new Date();
      const timeStr = now.toTimeString().split(' ')[0];
      const randomMsg = messages[Math.floor(Math.random() * messages.length)];
      const randomComp = components[Math.floor(Math.random() * components.length)];
      const randomLvl = levels[Math.floor(Math.random() * levels.length)];

      setLogs((prev) => [
        { timestamp: timeStr, level: randomLvl, message: randomMsg, node: randomComp },
        ...prev.slice(0, 12),
      ]);

      // Randomly update agent tokens processed
      setEmployees((prev) => prev.map(emp => {
        if (emp.status === "executing" || emp.status === "thinking") {
          return {
            ...emp,
            tokensProcessed: emp.tokensProcessed + Math.floor(Math.random() * 450)
          };
        }
        return emp;
      }));

    }, 3000);

    return () => clearInterval(interval);
  }, []);

  // Trigger SVG chart animation on mount/tab change
  useEffect(() => {
    setChartAnimatePercent(0);
    const duration = 800;
    const start = performance.now();
    let animId: number;

    const run = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      setChartAnimatePercent(progress);
      if (progress < 1) {
        animId = requestAnimationFrame(run);
      }
    };
    animId = requestAnimationFrame(run);
    return () => cancelAnimationFrame(animId);
  }, [activeTab]);

  const triggerSimulation = () => {
    setSimulating(true);
    // Simulate node state progression
    setWorkflowNodes(prev => prev.map((node, i) => i === 0 ? { ...node, status: "active" } : node));
    
    setTimeout(() => {
      setWorkflowNodes(prev => prev.map((node, i) => {
        if (i === 0) return { ...node, status: "success" };
        if (i === 1) return { ...node, status: "active" };
        return node;
      }));
    }, 1000);

    setTimeout(() => {
      setWorkflowNodes(prev => prev.map((node, i) => {
        if (i === 1) return { ...node, status: "success" };
        if (i === 2) return { ...node, status: "active" };
        return node;
      }));
    }, 2000);

    setTimeout(() => {
      setWorkflowNodes(prev => prev.map((node, i) => {
        if (i === 2) return { ...node, status: "success" };
        if (i === 3) return { ...node, status: "active" };
        return node;
      }));
    }, 3000);

    setTimeout(() => {
      setWorkflowNodes(prev => prev.map((node, i) => {
        if (i === 3) return { ...node, status: "success" };
        return node;
      }));
      setSimulating(false);
    }, 4000);
  };

  return (
    <div className="bg-oceanic-noir text-arctic-powder min-h-screen flex relative overflow-hidden">
      {/* 1. COLLAPSIBLE SIDEBAR */}
      <aside 
        className={`bg-nocturnal-expedition border-r border-mystic-mint/10 p-5 flex flex-col justify-between transition-all duration-300 z-30 ${
          sidebarCollapsed ? "w-20" : "w-64"
        }`}
      >
        <div className="flex flex-col gap-8">
          {/* Brand Logo & Toggle */}
          <div className="flex items-center justify-between border-b border-mystic-mint/10 pb-4">
            {!sidebarCollapsed && (
              <div className="flex items-center gap-2 font-sans font-extrabold text-sm tracking-tight text-white">
                <div className="w-6 h-6 rounded-lg bg-forsythia flex items-center justify-center text-oceanic-noir">
                  <Zap className="w-3.5 h-3.5 fill-current" />
                </div>
                <span>NeuralOS Core</span>
              </div>
            )}
            {sidebarCollapsed && (
              <div className="w-8 h-8 rounded-lg bg-forsythia flex items-center justify-center text-oceanic-noir mx-auto">
                <Zap className="w-4 h-4 fill-current" />
              </div>
            )}
            <button 
              onClick={() => setSidebarCollapsed(!sidebarCollapsed)}
              className="p-1 bg-oceanic-noir rounded border border-mystic-mint/10 text-mystic-mint/60 hover:text-white"
            >
              {sidebarCollapsed ? <ChevronRight className="w-4.5 h-4.5" /> : <ChevronLeft className="w-4.5 h-4.5" />}
            </button>
          </div>

          {/* Navigation Links */}
          <nav className="flex flex-col gap-2">
            {[
              { id: "orchestrator", label: "Orchestrator Mesh", icon: Cpu },
              { id: "analytics", label: "System Analytics", icon: Activity },
              { id: "agents", label: "Autonomous Agents", icon: Layers },
            ].map((navItem) => {
              const Icon = navItem.icon;
              const isActive = activeTab === navItem.id;
              return (
                <button
                  key={navItem.id}
                  onClick={() => setActiveTab(navItem.id as any)}
                  className={`w-full flex items-center gap-3 p-3 rounded-xl font-mono text-xs text-left transition-all cursor-pointer ${
                    isActive
                      ? "bg-forsythia text-oceanic-noir font-bold"
                      : "text-mystic-mint/60 hover:bg-nocturnal-expedition/50 hover:text-white"
                  }`}
                >
                  <Icon className="w-4 h-4 shrink-0" />
                  {!sidebarCollapsed && <span>{navItem.label}</span>}
                </button>
              );
            })}
          </nav>
        </div>

        {/* System Vitality Badge */}
        <div className="border-t border-mystic-mint/10 pt-4 flex flex-col gap-2">
          <div className="flex items-center gap-2">
            <div className="w-2.5 h-2.5 bg-emerald-400 rounded-full animate-pulse" />
            {!sidebarCollapsed && <span className="font-mono text-[9px] text-white">SYS_DECRYPT_SECURE</span>}
          </div>
          {!sidebarCollapsed && (
            <div className="font-mono text-[8px] text-mystic-mint/40">
              Uptime: 99.982% <br />
              Region: Global-Core
            </div>
          )}
        </div>
      </aside>

      {/* MAIN PANEL CONTENT */}
      <main className="flex-1 flex flex-col min-w-0 bg-oceanic-noir">
        {/* TOP NAVIGATION HEAD */}
        <header className="h-16 border-b border-mystic-mint/10 px-6 flex items-center justify-between bg-nocturnal-expedition/20">
          <div className="flex items-center gap-4">
            <span className="font-mono text-xs font-bold text-white uppercase tracking-wider">
              {activeTab === "orchestrator" && "Orchestrator Console"}
              {activeTab === "analytics" && "Advanced Performance Grids"}
              {activeTab === "agents" && "AI Team Members Management"}
            </span>
          </div>

          <div className="flex items-center gap-4 relative">
            {/* Command Palette Button */}
            <button 
              onClick={() => setCommandPaletteOpen(!commandPaletteOpen)}
              className="p-2 bg-nocturnal-expedition/60 border border-mystic-mint/10 rounded-lg text-mystic-mint/60 hover:text-white flex items-center gap-2 cursor-pointer text-xs font-mono"
            >
              <Command className="w-3.5 h-3.5" />
              <span className="hidden sm:inline">⌘K Terminal</span>
            </button>

            {/* Pulsing Notification Badge */}
            <button 
              onClick={() => {
                setNotificationCount(0);
                alert("SysLog Alert: System completed Vercel pipeline compilation in 1.4ms without exceptions.");
              }}
              className="p-2 bg-nocturnal-expedition/60 border border-mystic-mint/10 rounded-lg text-mystic-mint/60 hover:text-white relative cursor-pointer"
            >
              <Bell className="w-4 h-4" />
              {notificationCount > 0 && (
                <span className="absolute -top-1 -right-1 w-2.5 h-2.5 bg-forsythia rounded-full animate-pulse border border-oceanic-noir" />
              )}
            </button>
          </div>
        </header>

        {/* COMMAND PALETTE POPUP */}
        {commandPaletteOpen && (
          <div className="absolute inset-0 bg-oceanic-noir/80 backdrop-blur-md z-40 flex items-center justify-center p-6">
            <div className="bg-nocturnal-expedition border border-mystic-mint/20 w-full max-w-lg rounded-2xl p-6 relative">
              <div className="flex items-center justify-between border-b border-mystic-mint/10 pb-3 mb-4">
                <span className="text-xs font-mono text-white">NeuralOS Shell Access</span>
                <button onClick={() => setCommandPaletteOpen(false)} className="text-xs text-forsythia font-mono">[CLOSE]</button>
              </div>
              <input 
                type="text" 
                autoFocus
                placeholder="Type shell command (e.g. system_restart, swarm_sync, shield_flush)..."
                className="w-full bg-oceanic-noir border border-mystic-mint/10 p-3 rounded-lg text-xs font-mono text-white focus:outline-none focus:border-forsythia"
                onKeyDown={(e) => {
                  if (e.key === "Enter") {
                    alert("System response: Command queued. Executing in isolated container thread.");
                    setCommandPaletteOpen(false);
                  }
                }}
              />
              <div className="mt-4 flex flex-col gap-2 font-mono text-[10px] text-mystic-mint/50">
                <p>💡 Hint: Type <span className="text-white">"swarm_sync"</span> to sync worker thread cache states.</p>
                <p>💡 Type <span className="text-white">"system_restart"</span> to clear regional routing caches.</p>
              </div>
            </div>
          </div>
        )}

        {/* INNER DOCK PANELS */}
        <div className="flex-1 overflow-y-auto p-6 flex flex-col gap-8">
          
          {/* TAB 1: ORCHESTRATOR MESH VIEW */}
          {activeTab === "orchestrator" && (
            <div className="flex flex-col gap-8">
              
              {/* Quick status cards */}
              <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                {[
                  { title: "Dynamic Routing Efficiency", value: "99.98%", sub: "Nominal", color: "text-emerald-400" },
                  { title: "Sub-10ms Routing Health", value: "8.42ms", sub: "-1.4ms savings", color: "text-forsythia" },
                  { title: "Connected Client Lanes", value: "42,910", sub: "+890 this cycle", color: "text-white" },
                  { title: "Daily API Burn Rate", value: "$4.12", sub: "Optimized savings", color: "text-deep-saffron" }
                ].map((stat, idx) => (
                  <div key={idx} className="bg-nocturnal-expedition/20 border border-mystic-mint/10 p-5 rounded-2xl">
                    <span className="text-[10px] font-mono text-mystic-mint/40 uppercase block mb-1">{stat.title}</span>
                    <span className={`text-2xl font-mono font-bold ${stat.color}`}>{stat.value}</span>
                    <span className="text-[10px] font-mono text-mystic-mint/50 block mt-1">✓ {stat.sub}</span>
                  </div>
                ))}
              </div>

              {/* Workflow builder and Logs layout */}
              <div className="grid grid-cols-1 lg:grid-cols-12 gap-8">
                
                {/* Workflow Builder */}
                <div className="lg:col-span-7 bg-nocturnal-expedition/20 border border-mystic-mint/10 p-6 rounded-3xl flex flex-col justify-between">
                  <div>
                    <div className="flex items-center justify-between mb-4">
                      <span className="text-xs font-mono text-forsythia font-bold">Interactive Route Builder</span>
                      <button 
                        onClick={triggerSimulation}
                        disabled={simulating}
                        className="py-1 px-3 bg-forsythia text-oceanic-noir font-mono text-[9px] font-bold uppercase rounded hover:bg-white cursor-pointer disabled:opacity-50"
                      >
                        {simulating ? "EXECUTING..." : "COMPILE WORKFLOW"}
                      </button>
                    </div>
                    <p className="text-xs text-mystic-mint/60 font-sans mb-8">
                      Click the buttons below to manually route packet payloads and check node health logs in real-time.
                    </p>
                  </div>

                  {/* Flow Steps Layout */}
                  <div className="flex flex-col gap-4 relative">
                    {workflowNodes.map((node, idx) => (
                      <div 
                        key={node.id}
                        className={`p-4 rounded-xl border flex items-center justify-between transition-all ${
                          node.status === "active" 
                            ? "bg-nocturnal-expedition border-forsythia shadow shadow-forsythia/10" 
                            : node.status === "success"
                            ? "bg-nocturnal-expedition/40 border-emerald-500/30"
                            : "bg-oceanic-noir/50 border-mystic-mint/5"
                        }`}
                      >
                        <div className="flex items-center gap-3">
                          <div className={`p-1.5 rounded font-mono text-[9px] font-bold ${
                            node.status === "active" ? "bg-forsythia text-oceanic-noir" : "bg-nocturnal-expedition text-white"
                          }`}>
                            NODE_{idx+1}
                          </div>
                          <div>
                            <h4 className="text-xs font-mono font-bold text-white">{node.label}</h4>
                            <p className="text-[10px] font-sans text-mystic-mint/50">{node.description}</p>
                          </div>
                        </div>

                        {/* Status Label */}
                        <span className={`text-[10px] font-mono uppercase px-2 py-0.5 rounded ${
                          node.status === "active" 
                            ? "bg-forsythia/10 text-forsythia" 
                            : node.status === "success"
                            ? "bg-emerald-500/10 text-emerald-400"
                            : "bg-mystic-mint/5 text-mystic-mint/30"
                        }`}>
                          {node.status}
                        </span>
                      </div>
                    ))}
                  </div>
                </div>

                {/* Live Activity Feed */}
                <div className="lg:col-span-5 bg-oceanic-noir border border-mystic-mint/10 rounded-3xl p-6 flex flex-col justify-between min-h-[380px]">
                  <div>
                    <div className="flex items-center justify-between border-b border-mystic-mint/10 pb-3 mb-4">
                      <span className="text-xs font-mono text-white">Live Activity Stream</span>
                      <span className="w-2 h-2 bg-forsythia rounded-full animate-ping" />
                    </div>
                    <p className="text-[11px] font-sans text-mystic-mint/50 mb-6">Updates live on container channel stream every 3s.</p>
                  </div>

                  {/* Scroller Area */}
                  <div className="flex-1 overflow-y-auto max-h-[300px] flex flex-col gap-3 pr-1">
                    {logs.map((log, index) => (
                      <div key={index} className="p-3 bg-nocturnal-expedition/30 border border-mystic-mint/5 rounded-xl font-mono text-[10px]">
                        <div className="flex justify-between text-mystic-mint/40 mb-1">
                          <span>{log.timestamp} | {log.node}</span>
                          <span className={
                            log.level === "CRITICAL" ? "text-red-400" :
                            log.level === "WARNING" ? "text-deep-saffron" :
                            log.level === "SUCCESS" ? "text-emerald-400" : "text-forsythia"
                          }>
                            {log.level}
                          </span>
                        </div>
                        <p className="text-white leading-relaxed">{log.message}</p>
                      </div>
                    ))}
                  </div>
                </div>

              </div>
            </div>
          )}

          {/* TAB 2: SYSTEM ANALYTICS VIEW */}
          {activeTab === "analytics" && (
            <div className="flex flex-col gap-8">
              {/* Core charts */}
              <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                {/* Custom SVG Line Chart (No Library) */}
                <div className="bg-nocturnal-expedition/20 border border-mystic-mint/10 p-6 rounded-3xl">
                  <h3 className="text-xs font-mono text-forsythia font-bold mb-1">REAL-TIME BANDWIDTH TRANSACTIONS</h3>
                  <p className="text-xs text-mystic-mint/50 mb-6 font-sans">Plotting transaction volume across AP, US, and EU clusters.</p>

                  <div className="relative w-full h-48 bg-oceanic-noir/50 border border-mystic-mint/5 rounded-xl flex items-center justify-center p-4">
                    {/* SVG Chart */}
                    <svg className="w-full h-full" viewBox="0 0 400 150">
                      <defs>
                        <linearGradient id="chart-glow" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="0%" stopColor="#FFC801" stopOpacity="0.3" />
                          <stop offset="100%" stopColor="#FFC801" stopOpacity="0" />
                        </linearGradient>
                      </defs>
                      {/* Grid Lines */}
                      <line x1="0" y1="30" x2="400" y2="30" stroke="#114C5A" strokeOpacity="0.4" strokeWidth="0.5" />
                      <line x1="0" y1="75" x2="400" y2="75" stroke="#114C5A" strokeOpacity="0.4" strokeWidth="0.5" />
                      <line x1="0" y1="120" x2="400" y2="120" stroke="#114C5A" strokeOpacity="0.4" strokeWidth="0.5" />
                      
                      {/* Animate-on-scroll dynamic graph line */}
                      <path 
                        d={`M 10 130 Q 80 40 150 90 T 300 20 T 390 120`} 
                        fill="none" 
                        stroke="#FFC801" 
                        strokeWidth="3" 
                        strokeDasharray="1000"
                        strokeDashoffset={1000 - (1000 * chartAnimatePercent)}
                        className="transition-all duration-1000"
                      />
                      
                      {/* Filled Glow Area */}
                      <path 
                        d={`M 10 130 Q 80 40 150 90 T 300 20 T 390 120 L 390 150 L 10 150 Z`} 
                        fill="url(#chart-glow)" 
                        opacity={chartAnimatePercent}
                      />

                      {/* Moving value dot */}
                      <circle cx="300" cy="20" r="5" fill="#FF9932" opacity={chartAnimatePercent} />
                    </svg>

                    {/* Chart Legend values */}
                    <div className="absolute bottom-2 left-4 right-4 flex justify-between font-mono text-[9px] text-mystic-mint/40">
                      <span>02:00</span>
                      <span>02:30</span>
                      <span>03:00</span>
                      <span>03:30</span>
                      <span>04:00</span>
                    </div>
                  </div>
                </div>

                {/* Custom Bar Chart (No Library) */}
                <div className="bg-nocturnal-expedition/20 border border-mystic-mint/10 p-6 rounded-3xl">
                  <h3 className="text-xs font-mono text-forsythia font-bold mb-1">SAVINGS COMPARED TO STANDARD API</h3>
                  <p className="text-xs text-mystic-mint/50 mb-6 font-sans">Percentage reduced by global model cache pooling.</p>

                  <div className="w-full h-48 bg-oceanic-noir/50 border border-mystic-mint/5 rounded-xl flex items-end justify-between p-6">
                    {[
                      { month: "JAN", val: 40 },
                      { month: "FEB", val: 55 },
                      { month: "MAR", val: 32 },
                      { month: "APR", val: 80 },
                      { month: "MAY", val: 92 },
                    ].map((item, i) => (
                      <div key={i} className="flex flex-col items-center gap-2 w-12">
                        {/* Interactive columns */}
                        <div 
                          style={{ height: `${item.val * chartAnimatePercent}%`, maxHeight: '120px' }}
                          className="w-8 bg-gradient-to-t from-deep-saffron to-forsythia rounded-t-lg transition-all duration-700" 
                        />
                        <span className="font-mono text-[9px] text-mystic-mint/40">{item.month}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* TAB 3: AUTONOMOUS AGENTS VIEW */}
          {activeTab === "agents" && (
            <div className="flex flex-col gap-8">
              <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                {employees.map((emp) => (
                  <div key={emp.id} className="bg-nocturnal-expedition/20 border border-mystic-mint/10 p-6 rounded-3xl hover-card-interactive gpu-accelerated">
                    <div className="flex items-center gap-3 mb-4">
                      <div className="w-10 h-10 bg-nocturnal-expedition border border-forsythia flex items-center justify-center font-bold text-forsythia rounded-xl">
                        {emp.avatar}
                      </div>
                      <div>
                        <h4 className="text-sm font-sans font-bold text-white">{emp.name}</h4>
                        <span className="font-mono text-[9px] text-forsythia uppercase">{emp.role}</span>
                      </div>
                    </div>

                    <div className="bg-oceanic-noir/80 border border-mystic-mint/5 p-4 rounded-2xl mb-4 text-xs font-mono">
                      <span className="text-mystic-mint/40 block mb-1">ACTIVE TASK:</span>
                      <p className="text-white">{emp.activeTask}</p>
                    </div>

                    <div className="flex justify-between items-center text-xs font-mono">
                      <div>
                        <span className="text-mystic-mint/40 block">TOKENS</span>
                        <span className="text-white font-bold">{(emp.tokensProcessed).toLocaleString()}</span>
                      </div>
                      <div className="text-right">
                        <span className="text-mystic-mint/40 block">EFFICIENCY</span>
                        <span className="text-forsythia font-bold">{emp.efficiency}%</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

        </div>
      </main>
    </div>
  );
}
